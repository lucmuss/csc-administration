DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
# Database (PostgreSQL)
DATABASE_NAME=csc
DATABASE_USER=csc
DATABASE_PASSWORD=csc
DATABASE_HOST=localhost
DATABASE_PORT=5434
# Alternative keys also supported:
# DB_NAME=...
# DB_USER=...
# DB_PASSWORD=...
# DB_HOST=...
# DB_PORT=...
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Absolut-URL der Instanz (fuer E-Mail-Tracking-Pixel u.a.)
SITE_URL=http://localhost:8000
APP_NAME=CSC Administration
APP_TAGLINE=Vorstand, Mitglieder, Compliance
APP_DESCRIPTION=Verwaltungssoftware fuer Social Clubs mit Mitglieder-, Finanz- und Governance-Modulen.

# E-Mail-Versand: console | smtp | resend | file | mailpit
# Fuer Agenten-/E2E-Tests mit Mailpit:
# EMAIL_DELIVERY_MODE=mailpit
# EMAIL_HOST=mailpit
# EMAIL_PORT=1025
# EMAIL_USE_TLS=0
# EMAIL_USE_SSL=0
EMAIL_DELIVERY_MODE=console
DEFAULT_FROM_EMAIL=noreply@localhost
USE_RESEND=0
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# Mailpit HTTP/API (fuer Inbox-Checks durch Agenten)
MAILPIT_HTTP_URL=http://localhost:8025
MAILPIT_API_URL=http://localhost:8025/api/v1
# Optional: Link in der Verwaltungsnavigation fuer Vorstand/Mitarbeiter anzeigen
MAILPIT_UI_ENABLED=1

# Google Analytics (leer lassen um zu deaktivieren)
GA_TRACKING_ID=

# Dev-Login fuer lokale GUI-Tests
TEST_USER_EMAIL=
DEV_LOGIN_ALLOWED_DOMAIN=@test.local

# Vereins-Konfiguration
MEMBER_CAPACITY=500
LOW_STOCK_THRESHOLD_EUR=25.00
BALANCE_TOPUP_MIN_AMOUNT=1.00
BALANCE_TOPUP_MAX_AMOUNT=500.00
CLUB_NAME=
CLUB_SLOGAN=
CLUB_CONTACT_EMAIL=
CLUB_SUPPORT_EMAIL=
CLUB_CONTACT_PHONE=
CLUB_TELEGRAM_URL=
CLUB_WHATSAPP_URL=
CLUB_CONTACT_ADDRESS=
CLUB_BOARD_REPRESENTATIVES=
CLUB_REGISTER_ENTRY=
CLUB_REGISTER_COURT=
CLUB_TAX_NUMBER=
CLUB_VAT_ID=
CLUB_SUPERVISORY_AUTHORITY=
CLUB_CONTENT_RESPONSIBLE=
CLUB_RESPONSIBLE_PERSON=
CLUB_MEMBERSHIP_EMAIL=
CLUB_PREVENTION_EMAIL=
CLUB_FINANCE_EMAIL=
CLUB_PRIVACY_CONTACT=
CLUB_DATA_PROTECTION_OFFICER=
CLUB_LANGUAGE_NOTICE=
CLUB_LEGAL_BASIS_NOTICE=
CLUB_RETENTION_NOTICE=
# Kommagetrennte Liste, z. B. Stripe fuer Zahlungen, Resend fuer E-Mail, externes Monitoring
CLUB_EXTERNAL_SERVICES=
CLUB_PREVENTION_OFFICER_NAME=
CLUB_PREVENTION_NOTICE=
CLUB_INSTAGRAM_URL=
CLUB_EMAIL_SIGNATURE_TEXT=
CLUB_EMAIL_SIGNATURE_HTML=
OVERADMIN_EMAILS=
CLUB_REGISTRATION_EMAIL_VERIFICATION_REQUIRED=1
CLUB_REGISTRATION_REMINDER_DAYS=7,14
IBAN_API_VALIDATION_ENABLED=1
IBAN_API_VALIDATION_ENDPOINT=https://openiban.com/validate/{iban}?getBIC=true&validateBankCode=true
MEMBER_EMAIL_VERIFICATION_REQUIRED=1
OPENROUTER_OCR_MODEL=
VERIFICATION_DOCUMENT_RETENTION_DAYS=30
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
HEALTH_ALLOWED_IPS=127.0.0.1,::1,localhost
OPENROUTER_API_KEY=
OPENROUTER_MODEL=Qwen/Qwen3.5-27B
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=CSC Administration
