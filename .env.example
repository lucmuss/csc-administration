DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DATABASE_NAME=csc
DATABASE_USER=csc
DATABASE_PASSWORD=csc
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Absolut-URL der Instanz (fuer E-Mail-Tracking-Pixel u.a.)
SITE_URL=http://localhost:8000

# E-Mail-Versand: console | smtp | resend
EMAIL_DELIVERY_MODE=console
DEFAULT_FROM_EMAIL=noreply@localhost
USE_RESEND=0
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Google Analytics (leer lassen um zu deaktivieren)
GA_TRACKING_ID=

# Dev-Login fuer lokale GUI-Tests
TEST_USER_EMAIL=
DEV_LOGIN_ALLOWED_DOMAIN=@test.local

# Vereins-Konfiguration
MEMBER_CAPACITY=500
LOW_STOCK_THRESHOLD_EUR=25.00
