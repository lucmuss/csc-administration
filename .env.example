DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DATABASE_NAME=csc
DATABASE_USER=csc
DATABASE_PASSWORD=csc
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Absolut-URL der Instanz (fuer E-Mail-Tracking-Pixel u.a.)
SITE_URL=http://localhost:8000
APP_NAME=CSC Administration
APP_TAGLINE=Vorstand, Mitglieder, Compliance
APP_DESCRIPTION=Verwaltungssoftware fuer Social Clubs mit Mitglieder-, Finanz- und Governance-Modulen.

# E-Mail-Versand: console | smtp | resend
EMAIL_DELIVERY_MODE=console
